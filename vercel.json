{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.py"
    }
  ],
  "env": {
    "BOT_TOKEN": "@bot_token",
    "GROQ_API_KEY": "@groq_api_key",
    "WEBHOOK_URL": "@webhook_url"
  }
}
