{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.py"
    }
  ],
  "env": {
    "BOT_TOKEN": "@bot_token",
    "GROQ_API_KEY": "@groq_api_key",
    "WEBHOOK_URL": "@webhook_url"
  },
  "functions": {
    "api/webhook.py": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}
